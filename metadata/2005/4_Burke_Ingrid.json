    "descriptions": [
      {
        "lang": "en",
        "description": "This study is an analysis of the changes in the epiphytic communities associated with ferns. As fronds age these communities on the fronds undergo a process of succession. Epiphyte cover generally increases with the age of the frond. However, while particular ferns demonstrated a classical progression of cover from young to old, others seemed to show no progression, simply because there was little cover on any fronds. Invertebrates were associated with older fronds and never with the youngest fronds. These results are discussed in the context of generalized patterns of ecological succession and the mechanisms underlying the patterns.",
        "descriptionType": "Abstract"
      }
    ],
    "title": [
      {
        "lang": "en",
        "title": "Succession in the phyllosphere: A case study on the giant fern (Angiopteris evecta)"
      }
    ],
