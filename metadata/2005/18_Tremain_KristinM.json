    "descriptions": [
      {
        "lang": "en",
        "description": "Holothurians are a large and diverse group of echinoderms that inhabit the oceans of the world. Here, a phylogeny is created based on morphological data of the sea cucumbers of Moorea, French Polynesia, to test colonization theory. This phylogeny is based on 11 local intertidal species. The phylogeny reveals that phylogenetic clumping is the mechanism of Holothurian colonization on the island of Moorea.",
        "descriptionType": "Abstract"
      }
    ],
    "title": [
      {
        "lang": "en",
        "title": "Patterns of community composition: A phylogeny of the holothurians of Moorea"
      }
