    "descriptions": [
      {
        "lang": "en",
        "description": "The nudibranchs Chromodors lochi and Glossodoris cincta are common subtidal lagoon predators of sessile animals in the South Pacific. In the presence of odor and current, G. cincta orient upstream and over 80% successfully locate the prey. Similar behavior was exhibited in C. lochi when conspecifics were included in the odor plume with prey. In all cases, the presence of flow is an essential condition for locating distant prey.",
        "descriptionType": "Abstract"
      }
    ],
    "title": [
      {
        "lang": "en",
        "title": "Effects of current and prey odor on two nudibranch species, Glossodoris cincta and Chromodoris lochi"
      }
