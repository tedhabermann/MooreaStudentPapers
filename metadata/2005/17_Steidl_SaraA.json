    "descriptions": [
      {
        "lang": "en",
        "description": "Habitat selection in plants has recently been a topic of much discussion because plants environment by evolving in order to not have strict habitat requirements. Habitat selection in plants is defined by dispersal ability, sources available, and community dynamics. Fagraea berteroana is an epiphytic plant that has demonstrated its flexibility in habitat selection by establishing a population at a lower elevation. With the right dispersers, neighbors, substrates and light exposure it has selected an ideal habitat.",
        "descriptionType": "Abstract"
      }
    ],
    "title": [
      {
        "lang": "en",
        "title": "Biology of Fagraea berteroana: Habitat specialization and conditions for biological success of an anomalous population"
      }
